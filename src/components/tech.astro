---
import "../styles/global.css";
import "../styles/themes.css";
import { Icon } from "astro-icon/components";
import { languages } from "../data/languages";
import { libraries } from "../data/libraries";

const sections = [
  { title: "Languages", items: languages },
  { title: "Libraries / Tools", items: libraries }
];
---

<section id="tech" class="section-container">
  <div class="container mx-auto">

    <!-- HEADER -->
    <div class="tech-header mb-16">
      <h2 class="text-2xl font-semibold mb-6">
        <span class="text-accent"> Tech Stack
      </h2>
      <p class="text-muted-foreground font-body text-sm">
        Languages, tools, and libraries I use across projects.
      </p>
    </div>
    <div class="space-y-8">
      {sections.map((section) => (
        <div class="space-y-4">

          <h3 class="text-foreground/60 font-body text-[11px] uppercase tracking-[0.4em] ml-1">
            {section.title}
          </h3>

          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-5">
            {section.items.map((item) => (
              <div class="skill-card opacity-0 group relative flex items-stretch min-h-14 rounded-xl
                          bg-accent/5 border border-accent/15">
              <!-- Stars badge -->
                <div class="absolute -bottom-3 -right-2 z-50 flex gap-0 px-1 py-0.5 rounded-md border border-border shadow-lg group-hover:border-accent/30" style="background-color: var(--secondary)">
                      {Array.from({ length: 5 }).map((_, i) => (
                        i < item.proficiency ? (
                          <span class="text-[10px]" style="color: var(--stars)">★</span>
                        ) : (
                          <span class="text-[10px]" style="color: var(--stars-empty)">★</span>
                        )
                ))} 
                </div>

                <!-- Icon strip -->
                <div class="shrink-0 w-12 flex items-center justify-center rounded-l-xl bg-accent/15 transition-colors group-hover:bg-accent/20">
                  <Icon name={item.icon} class="w-7 h-7 group-hover:scale-110 transition-transform duration-200" />
                </div>

                <!-- Name -->
                <div class="flex items-center justify-start px-1 py-1 overflow-hidden w-full">
                  <span class="font-body text-foreground/90 text-[13px] leading-tight font-medium tracking-tight line-clamp-2">
                    {item.name}
                  </span>
                </div>

              </div>
            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .tech-header {
    opacity: 0;
    transform: translateY(16px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skill-card {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
    transition: all .6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tech-header.reveal,
  .skill-card.reveal {
    opacity: 1 !important;
    transform: translateY(0) scale(1);
  }
</style>

<script>
  function reveal() {
    const header = document.querySelector(".tech-header");
    const cards = document.querySelectorAll(".skill-card");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target;

        if (el.classList.contains("tech-header")) {
          el.classList.add("reveal");
          observer.unobserve(el);
        }

        if (el.classList.contains("skill-card")) {
          const index = [...cards].indexOf(el);
          setTimeout(() => el.classList.add("reveal"), (index % 6) * 50);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    if (header) observer.observe(header);
    cards.forEach(card => observer.observe(card));
  }

  reveal();
  document.addEventListener("astro:after-swap", reveal);
</script>